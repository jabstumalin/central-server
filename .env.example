# Central Server Environment Variables
# Copy this file to .env and customize as needed
# Note: All these values have defaults in config.py, so .env is optional

# API Configuration
API_TITLE="Central Server API"
API_VERSION="1.0.0"
API_HOST="0.0.0.0"
API_PORT=8000

# Streamlit Configuration
STREAMLIT_PORT=8501

# CORS Settings (JSON array format)
CORS_ORIGINS=["*"]

# Database (uncomment and configure if needed)
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# ML Model Settings
MODEL_PATH="models/"
DEFAULT_MODEL="default"

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"
